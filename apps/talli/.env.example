# talli runs on 3001; motori (the auth host) on 3000.
PORT=3001

# Same database as motori — talli owns only the `talli` schema inside it.
DATABASE_URL=postgresql://motori:motori@localhost:5433/motori

# BetterAuth — MUST match motori's values exactly (shared session cookie).
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# talli's own canonical origin — csrf validates POSTs against this.
APP_ORIGIN=http://localhost:3001

# Hetzner Object Storage — same bucket as motori, talli/ key prefix.
STORAGE_ENDPOINT=https://hel1.your-objectstorage.com
STORAGE_BUCKET=motori-images
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_PUBLIC_URL=https://motori-images.hel1.your-objectstorage.com

# Private bucket for talli documents (rekisteriote etc.) — no public read access.
STORAGE_DOCS_BUCKET=motori-docs

# Resend — leave unset in dev to log emails to stdout instead of sending
# RESEND_API_KEY=re_...

# Cron secret — protects /api/cron endpoint
# CRON_SECRET=generate-a-random-string

# Optional — pino log level (default: info)
# LOG_LEVEL=debug

# Optional — OpenObserve sink (own stream, shared instance)
# OPENOBSERVE_URL=http://localhost:5080
# OPENOBSERVE_ORG=default
# OPENOBSERVE_STREAM=talli
# OPENOBSERVE_USER=admin@motori.local
# OPENOBSERVE_PASSWORD=motori
