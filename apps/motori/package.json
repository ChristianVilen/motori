{
	"name": "motori",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node --env-file-if-exists=.env .output/server/index.mjs",
		"db:migrate": "tsx --env-file-if-exists=.env src/lib/db/migrate.ts",
		"db:seed": "tsx --env-file-if-exists=.env src/lib/db/seed.ts",
		"db:codegen": "tsx --env-file-if-exists=.env src/lib/db/codegen.ts",
		"notify:expiry": "tsx --env-file-if-exists=.env src/lib/notify-expiry.ts",
		"purge:sessions": "tsx --env-file-if-exists=.env src/lib/purge-sessions.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@fontsource-variable/manrope": "5.2.8",
		"@fontsource-variable/space-grotesk": "5.2.10",
		"@fontsource/jetbrains-mono": "5.2.8",
		"@motori/db": "workspace:*",
		"@motori/server": "workspace:*",
		"@radix-ui/react-select": "2.2.6",
		"@radix-ui/react-slot": "1.2.4",
		"@tanstack/react-form": "1.29.0",
		"@tanstack/react-router": "1.168.18",
		"@tanstack/react-start": "1.167.32",
		"@types/leaflet": "1.9.21",
		"better-auth": "1.6.11",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"date-fns": "4.1.0",
		"embla-carousel-react": "8.6.0",
		"i18next": "25.10.10",
		"i18next-browser-languagedetector": "8.2.1",
		"kysely": "0.28.17",
		"leaflet": "1.9.4",
		"lucide-react": "1.8.0",
		"nitro": "3.0.260415-beta",
		"pg": "8.20.0",
		"react": "19.2.5",
		"react-day-picker": "9.14.0",
		"react-dom": "19.2.5",
		"react-i18next": "16.6.6",
		"react-leaflet": "5.0.0",
		"sonner": "2.0.7",
		"srvx": "0.11.15",
		"tailwind-merge": "3.5.0",
		"tsx": "4.21.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.2",
		"@playwright/test": "1.60.0",
		"@tailwindcss/vite": "4.2.2",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/node": "25.6.0",
		"@types/pg": "8.20.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"jsdom": "29.1.1",
		"kysely-codegen": "0.20.0",
		"tailwindcss": "4.2.2",
		"typescript": "6.0.2",
		"vite": "8.0.8",
		"vitest": "4.1.4"
	}
}
