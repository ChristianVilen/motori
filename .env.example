DATABASE_URL=postgresql://motori:motori@localhost:5433/motori

# BetterAuth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# CORS — comma-separated allowed origins (defaults to http://localhost:3000)
# ALLOWED_ORIGINS=https://motori.fi

# Hetzner Object Storage (S3-compatible, Helsinki hel1)
# Create a bucket in Hetzner Cloud Console -> Object Storage -> hel1
STORAGE_ENDPOINT=https://hel1.your-objectstorage.com
STORAGE_BUCKET=motori-images
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
# Public URL for objects — enable public access on the bucket in Hetzner Console
STORAGE_PUBLIC_URL=https://motori-images.hel1.your-objectstorage.com
