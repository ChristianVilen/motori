DATABASE_URL=postgresql://motori:motori@localhost:5433/motori

# BetterAuth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# CORS — comma-separated allowed origins (defaults to BETTER_AUTH_URL)
# ALLOWED_ORIGINS=https://motori.fi

# Hetzner Object Storage (S3-compatible, Helsinki hel1)
# When STORAGE_ENDPOINT is set, images are uploaded to Hetzner; otherwise saved locally to /uploads/
# Bucket must have public read access for STORAGE_PUBLIC_URL to serve images.
STORAGE_ENDPOINT=https://hel1.your-objectstorage.com
STORAGE_BUCKET=motori-images
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_PUBLIC_URL=https://motori-images.hel1.your-objectstorage.com

# Resend — leave unset in dev to log emails to stdout instead of sending
# RESEND_API_KEY=re_...

# Optional — pino log level (default: info)
# LOG_LEVEL=debug

# Dev only — push pino logs to the local Loki (started by `pnpm dev` via docker compose),
# viewable in Grafana at http://localhost:3001. Unset to disable. Ignored in production
# (prod ships logs via Promtail).
# LOKI_URL=http://localhost:3100

# Cron secret — protects /api/cron endpoint
# CRON_SECRET=generate-a-random-string

# Dev only — enable "Sign in with Motori" SSO for the local Grafana (main checkout, :3001).
# Leave off in worktrees (they stay anonymous-admin). Set the same secret on both sides.
# GRAFANA_OAUTH_ENABLED=true
# GRAFANA_OIDC_SECRET=dev-grafana-oidc-secret
