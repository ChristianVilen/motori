{
	"name": "motori",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node --env-file-if-exists=.env .output/server/index.mjs",
		"db:migrate": "tsx --env-file-if-exists=.env src/lib/db/migrate.ts",
		"db:seed": "tsx --env-file-if-exists=.env src/lib/db/seed.ts",
		"db:codegen": "tsx --env-file-if-exists=.env src/lib/db/codegen.ts",
		"notify:expiry": "tsx --env-file-if-exists=.env src/lib/notify-expiry.ts",
		"purge:sessions": "tsx --env-file-if-exists=.env src/lib/purge-sessions.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "3.1030.0",
		"@better-auth/kysely-adapter": "1.6.3",
		"@radix-ui/react-select": "2.2.6",
		"@radix-ui/react-slot": "1.2.4",
		"@tanstack/react-form": "1.29.0",
		"@tanstack/react-router": "1.168.18",
		"@tanstack/react-start": "1.167.32",
		"better-auth": "1.6.3",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"embla-carousel-react": "8.6.0",
		"i18next": "25.10.10",
		"i18next-browser-languagedetector": "8.2.1",
		"kysely": "0.28.16",
		"lucide-react": "1.8.0",
		"nitro": "3.0.260415-beta",
		"pg": "8.20.0",
		"pino": "10.3.1",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-i18next": "16.6.6",
		"resend": "6.12.2",
		"sharp": "0.33.5",
		"srvx": "0.11.15",
		"tailwind-merge": "3.5.0",
		"zod": "4.3.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp"
		]
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.2",
		"@biomejs/biome": "2.4.11",
		"@playwright/test": "1.59.1",
		"@tailwindcss/vite": "4.2.2",
		"@types/node": "25.6.0",
		"@types/pg": "8.20.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"kysely-codegen": "0.20.0",
		"pino-pretty": "13.1.3",
		"tailwindcss": "4.2.2",
		"tsx": "4.21.0",
		"typescript": "6.0.2",
		"vite": "8.0.8",
		"vitest": "4.1.4"
	}
}
