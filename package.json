{
	"name": "vuokramoto",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node .output/server/index.mjs",
		"db:migrate": "tsx --env-file=.env src/lib/db/migrate.ts",
		"db:seed": "tsx --env-file=.env src/lib/db/seed.ts",
		"db:codegen": "tsx --env-file=.env src/lib/db/codegen.ts",
		"notify:expiry": "tsx --env-file=.env src/lib/notify-expiry.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "3.1030.0",
		"@aws-sdk/s3-request-presigner": "3.1030.0",
		"@better-auth/kysely-adapter": "1.6.3",
		"@radix-ui/react-select": "2.2.6",
		"@radix-ui/react-slot": "1.2.4",
		"@tanstack/react-form": "1.29.0",
		"@tanstack/react-router": "1.168.18",
		"@tanstack/react-start": "1.167.32",
		"@tanstack/zod-form-adapter": "0.42.1",
		"better-auth": "1.6.3",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"i18next": "25.10.10",
		"kysely": "0.28.16",
		"lucide-react": "1.8.0",
		"pg": "8.20.0",
		"pino": "10.3.1",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-i18next": "16.6.6",
		"resend": "6.12.2",
		"tailwind-merge": "3.5.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@playwright/test": "1.59.1",
		"@tailwindcss/vite": "4.2.2",
		"@types/node": "25.6.0",
		"@types/pg": "8.20.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"kysely-codegen": "0.20.0",
		"pino-pretty": "13.1.3",
		"tailwindcss": "4.2.2",
		"tsx": "4.21.0",
		"typescript": "6.0.2",
		"vite": "8.0.8",
		"vitest": "4.1.4"
	}
}
