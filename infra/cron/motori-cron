#!/usr/bin/env bash
# Trigger a single /api/cron task on the local Dokku app.
# Usage: motori-cron <task-name>
# Reads CRON_SECRET from dokku config at runtime so this script is safe to commit.
set -euo pipefail

task="${1:?task name required}"
secret="$(dokku config:get motori CRON_SECRET)"

curl -fsSk -X POST \
  --resolve motori.fi:443:127.0.0.1 \
  -H "Authorization: Bearer $secret" \
  "https://motori.fi/api/cron?task=$task" >/dev/null
