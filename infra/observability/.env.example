# OpenObserve runs as a Dokku app (`openobserve`) served at https://logs.motori.fi.
# These are the values to feed `dokku config:set openobserve ...` — NOT a compose
# env file. Fill secrets on the host; never commit real keys/passwords.
# See DEPLOY.md §11 for the full deploy sequence.

# Admin login for the public UI (logs.motori.fi). First boot creates this user.
ZO_ROOT_USER_EMAIL=admin@motori.fi
ZO_ROOT_USER_PASSWORD=change-me-strong-unique

# Telemetry off; single-node local mode; data dir (mounted via dokku storage)
ZO_TELEMETRY=false
ZO_LOCAL_MODE=true
ZO_DATA_DIR=/data

# S3 offload → existing PRIVATE motori-backups bucket, prefix openobserve/.
# Reuse the project-wide Hetzner keys (same as the app's STORAGE_* / backup auth).
ZO_LOCAL_MODE_STORAGE=s3
ZO_S3_PROVIDER=s3
ZO_S3_SERVER_URL=https://hel1.your-objectstorage.com
ZO_S3_REGION_NAME=hel1
ZO_S3_BUCKET_NAME=motori-backups
ZO_S3_BUCKET_PREFIX=openobserve/
ZO_S3_ACCESS_KEY=
ZO_S3_SECRET_KEY=
ZO_S3_FEATURE_FORCE_HOSTED_STYLE=false

# 30-day retention
ZO_COMPACT_DATA_RETENTION_DAYS=30

# Memory caps for the low-RAM VPS (the container is also capped via
# `dokku resource:limit --memory 1g`).
ZO_MEMORY_CACHE_ENABLED=false
ZO_MEMORY_CACHE_DATAFUSION_MAX_SIZE=256
ZO_MEM_TABLE_MAX_SIZE=128
ZO_MAX_FILE_SIZE_IN_MEMORY=128
ZO_FILE_MOVE_THREAD_NUM=1
