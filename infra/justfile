set shell := ["bash", "-c"]

compose := "docker compose --env-file /etc/motori.env -f /opt/motori/docker-compose.prod.yml"

# List available commands
default:
    @just --list

# --- Terraform ---

# Decrypt terraform.tfvars for use in shell (eval "$(just decrypt-tfvars)")
decrypt-tfvars:
    @sops --decrypt --input-type binary --output-type binary terraform.tfvars.enc > terraform.tfvars

# Preview infrastructure changes (requires terraform.tfvars — run decrypt-tfvars first)
plan:
    @test -f terraform.tfvars || (echo "error: terraform.tfvars not found — run: just decrypt-tfvars" && exit 1)
    terraform plan

# Apply infrastructure changes (requires terraform.tfvars — run decrypt-tfvars first)
apply:
    @test -f terraform.tfvars || (echo "error: terraform.tfvars not found — run: just decrypt-tfvars" && exit 1)
    terraform apply

# Force the server to be rebuilt on next apply (volume + IP survive — both delete-protected)
taint:
    terraform taint hcloud_server.app

# Rebuild the server from scratch — taint + apply
rebuild: taint apply

# Show all Terraform outputs
output:
    terraform output

# Print the server's public IPv4 (for Cloudflare A record)
ip:
    @terraform output -raw server_ip

# --- Server access ---

# Open an interactive SSH session
ssh:
    ssh root@app-server

# Show health of all containers and disk usage
status:
    ssh root@app-server " \
        echo '=== cloud-init ===' && cloud-init status && \
        echo '=== containers ===' && {{compose}} ps && \
        echo '=== disk ===' && df -h /var/lib/motori/pgdata"

# Tail the app logs
logs:
    ssh root@app-server "{{compose}} logs -f --tail=200 app"

# Fix Tailscale SSH MTU locally (run when SSH hangs but ping works)
fix-mtu:
    sudo ip link set tailscale0 mtu 1200

# --- Push secrets, config, certs ---

# Decrypt and push .env.production to /etc/motori.env
push-env:
    sops --decrypt --input-type binary --output-type binary ../.env.production.enc | ssh root@app-server "cat > /etc/motori.env"

# Rsync compose file + nginx config to /opt/motori/ (the only files the server needs from this repo)
push-config:
    ssh root@app-server "mkdir -p /opt/motori/nginx"
    rsync ../docker-compose.prod.yml root@app-server:/opt/motori/docker-compose.prod.yml
    rsync nginx/motori.conf root@app-server:/opt/motori/nginx/motori.conf

# Decrypt and push Cloudflare origin TLS certs, reload nginx
push-certs:
    sops --decrypt --input-type binary --output-type binary certs/motori.com.pem.enc | ssh root@app-server "cat > /etc/ssl/motori.fi.pem"
    sops --decrypt --input-type binary --output-type binary certs/motori.com.key.enc | ssh root@app-server "cat > /etc/ssl/motori.fi.key && chmod 600 /etc/ssl/motori.fi.key"
    ssh root@app-server "{{compose}} restart nginx"

# Log the server into GHCR. Reads infra/secrets/ghcr-token.enc (PAT with read:packages).
login:
    sops --decrypt --input-type binary --output-type binary secrets/ghcr-token.enc | tr -d '\n' | ssh root@app-server "docker login ghcr.io -u christianvilen --password-stdin"

# Install/update the motori app cron job (idempotent)
push-cron:
    ssh root@app-server "printf '0 3 * * * root curl -sf -X POST -H \"Authorization: Bearer \$(grep CRON_SECRET /etc/motori.env | cut -d= -f2-)\" http://localhost:3000/api/cron >> /var/log/motori-cron.log 2>&1\n' > /etc/cron.d/motori-cron && chmod 644 /etc/cron.d/motori-cron"

# --- Deploy ---

# Sync compose+nginx, pull GHCR images, run migrations, restart app + nginx. Roll back: just deploy tag=<sha>
deploy tag="latest": push-config
    ssh root@app-server "export MOTORI_TAG={{tag}} && \
        {{compose}} pull app migrate && \
        {{compose}} run --rm migrate && \
        {{compose}} up -d"

# Wait for Tailscale + cloud-init after a server rebuild
wait-for-server:
    @echo "→ waiting for cloud-init…"
    @while ! ssh -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=accept-new \
        root@app-server "cloud-init status --wait" >/dev/null 2>&1; do printf "."; sleep 5; done
    @echo " ready."

# First-time provisioning chain (GHCR login → env → config → certs → deploy). Use after `just rebuild`.
bootstrap: wait-for-server login push-env push-config push-certs deploy
    @echo "✓ Bootstrap complete. Verify: just status && curl -I https://motori.fi"

# Disaster recovery: rebuild + bootstrap
nuke: rebuild bootstrap

# --- Maintenance ---

# Restart the app container
restart:
    ssh root@app-server "{{compose}} restart app"

# Run a database backup right now
backup:
    ssh root@app-server "/usr/local/bin/db-backup"

# Open a psql shell
psql:
    ssh -t root@app-server "{{compose}} exec db psql -U appuser appdb"

# Grant admin role to a user: just make-admin email=user@example.com
make-admin email:
    ssh root@app-server "{{compose}} exec -T db psql -U appuser appdb -c \"UPDATE \\\"user\\\" SET role = 'admin' WHERE email = '{{email}}'; SELECT email, role FROM \\\"user\\\" WHERE email = '{{email}}';\""
